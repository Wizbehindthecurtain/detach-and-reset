# Public envs — both are inlined into the client bundle by Next at build time.
# Format freely; the components strip non-digits for tel:/sms: hrefs. Leave
# blank to surface the [ PHONE · TBD ] / [ SMS · TBD ] fallback pills.
NEXT_PUBLIC_BUSINESS_PHONE="(703) 651-0008"
NEXT_PUBLIC_PHOTO_SMS_NUMBER="(703) 226-9658"

# Public — read in the browser. Format freely (e.g. "(555) 123-4567"); PhoneLink
# strips non-digits for the tel: href. Leave blank to show a "TBD" pill in the
# Hero CTA + sticky header until provided.
NEXT_PUBLIC_BUSINESS_PHONE=
